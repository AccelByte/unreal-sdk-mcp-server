              },
              {
                "type": "AGSErrorState",
                "name": "ErrorPanel",
                "class_path": "/AccelByteUITools/AGSUI/Core/WBP_AGS_ErrorState.WBP_AGS_ErrorState_C",
                "is_variable": true
              }
            ]
          }
        ]
      }
    ]
  }
}
